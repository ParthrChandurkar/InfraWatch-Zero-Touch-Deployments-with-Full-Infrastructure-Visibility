{
  "annotations": {
    "list": []
  },
  "description": "Provisioned InfraWatch service health dashboard with uptime, API latency, request volume, and error rate panels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphOrientation": "auto",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "expr": "up{job=\"infrawatch-backend\"}",
          "legendFormat": "API up",
          "refId": "A"
        }
      ],
      "title": "API Availability",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(infrawatch_api_request_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{ route }} p95",
          "refId": "A"
        }
      ],
      "title": "API p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(infrawatch_deployments_total[5m]))",
          "legendFormat": "deployment actions",
          "refId": "A"
        }
      ],
      "title": "Deployment Action Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 40,
  "tags": [
    "infrawatch",
    "services"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "InfraWatch Service Health",
  "uid": "infrawatch-service-health",
  "version": 1,
  "weekStart": ""
}
